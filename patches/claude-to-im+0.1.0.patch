+function extractSkillMetadata(skillPath: string): { name: string; description?: string } {
+  const fallbackName = path.basename(path.dirname(skillPath));
+  try {
+    const content = fs.readFileSync(skillPath, 'utf8');
+    const frontmatter = content.match(/^---\n([\s\S]*?)\n---/);
+    if (!frontmatter) {
+      return { name: fallbackName };
+    }
+
+    let name = fallbackName;
+    let description: string | undefined;
+    for (const rawLine of frontmatter[1].split('\n')) {
+      const line = rawLine.trim();
+      if (line.startsWith('name:')) {
+        name = line.slice(5).trim().replace(/^['"]|['"]$/g, '') || fallbackName;
+      }
+      if (line.startsWith('description:')) {
+        const value = line.slice(12).trim();
+        if (value && value !== '|' && value !== '>') {
+          description = value.replace(/^['"]|['"]$/g, '');
+        }
+      }
+    }
+
+    return { name, ...(description ? { description } : {}) };
+  } catch {
+    return { name: fallbackName };
+  }
+}
+
+function collectSkillFiles(root: string): string[] {
+  if (!fs.existsSync(root)) return [];
+
+  const results: string[] = [];
+  const queue = [root];
+  while (queue.length > 0) {
+    const current = queue.shift()!;
+    let entries: fs.Dirent[];
+    try {
+      entries = fs.readdirSync(current, { withFileTypes: true });
+    } catch {
+      continue;
+    }
+
+    for (const entry of entries) {
+      const fullPath = path.join(current, entry.name);
+      if (entry.isDirectory()) {
+        queue.push(fullPath);
+      } else if (entry.isFile() && entry.name === 'SKILL.md') {
+        results.push(fullPath);
+      }
+    }
+  }
+
+  return results;
+}
