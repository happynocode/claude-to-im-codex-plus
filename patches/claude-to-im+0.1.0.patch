+  if (callbackData === 'skill:clear') return { action: 'clear' };
+  const parts = callbackData.split(':');
+  if (parts.length < 3 || parts[1] !== 'use') return null;
+  return { action: 'use', skillName: decodeURIComponent(parts.slice(2).join(':')) };
