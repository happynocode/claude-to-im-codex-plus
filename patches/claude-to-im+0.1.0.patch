+function parseProviderCallback(callbackData: string): { action: 'use'; providerId: string } | { action: 'clear' } | null {
+  if (!callbackData.startsWith('provider:')) return null;
+  if (callbackData === 'provider:clear') return { action: 'clear' };
+  const parts = callbackData.split(':');
+  if (parts.length < 3 || parts[1] !== 'use') return null;
+  return { action: 'use', providerId: decodeURIComponent(parts.slice(2).join(':')) };
+}
