+export function listAvailableSkills(runtime: SkillsRuntime = getSkillsRuntime()): SkillInfo[] {
+  const seen = new Set<string>();
+  const skills: SkillInfo[] = [];
+
+  for (const { source, root } of getSkillRoots(runtime)) {
+    for (const skillPath of collectSkillFiles(root)) {
+      const relativePath = path.relative(root, skillPath);
+      const { name, description } = extractSkillMetadata(skillPath);
+      const dedupKey = `${source}:${relativePath}`;
+      if (seen.has(dedupKey)) continue;
+      seen.add(dedupKey);
+      skills.push({
+        name,
+        source,
+        relativePath,
+        ...(description ? { description } : {}),
+      });
+    }
+  }
+
+  return skills.sort((left, right) => {
+    if (left.source !== right.source) return left.source.localeCompare(right.source);
+    return left.name.localeCompare(right.name);
+  });
+}
