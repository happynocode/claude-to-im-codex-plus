+  const parsed = parseProviderCallback(msg.callbackData || '');
+  if (!parsed) return false;
+
+  const binding = router.resolve(msg.address);
+  const result = parsed.action === 'clear'
+    ? buildUseProviderCommandResult(binding, 'clear')
+    : buildUseProviderCommandResult(binding, parsed.providerId);
+
+  await deliver(adapter, {
+    address: msg.address,
+    text: result.response,
+    parseMode: 'HTML',
+    inlineButtons: result.responseButtons,
+    replyToMessageId: msg.callbackMessageId || msg.messageId,
+  });
+  return true;
+}
